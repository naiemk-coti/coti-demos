# Environment variables for Millionaire Comparison
# Copy this file to .env and fill in your actual values

# Sepolia RPC URL (default used by UI when not set)
VITE_APP_NODE_HTTPS_ADDRESS=https://rpc.sepolia.org

# Deployed MillionaireComparison Contract Address (on Sepolia)
VITE_CONTRACT_ADDRESS=

# POD encryption: "testnet" | "mainnet" or full URL. If you get 404, set VITE_POD_ENCRYPTION_URL to the exact endpoint.
# VITE_POD_ENCRYPTION_NETWORK=testnet
# VITE_POD_ENCRYPTION_URL=https://fullnode.testnet.coti.io/pod-encryption

# Optional: gas limit for "compare wealth" tx (default 3000000); increase if you get "out of gas"
# VITE_COMPARE_GAS_LIMIT=3000000

# Alice Account (First Millionaire)
VITE_ALICE_PK=
VITE_ALICE_AES_KEY=

# Bob Account (Second Millionaire)
VITE_BOB_PK=
VITE_BOB_AES_KEY=

# Deployer Account (for hardhat deployment)
DEPLOYER_PRIVATE_KEY=

SEPOLIA_RPC_URL=

ETHERSCAN_API_KEY=