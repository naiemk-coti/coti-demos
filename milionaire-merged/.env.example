# Merged UI: `/coti` and `/sepolia` read different env keys (no runtime remapping).
# Copy to `.env` and restart `npm run dev` after changes.

# --- COTI Testnet page (`/coti`) — useMillionaireContractCoti ---
VITE_ALICE_PK_FOR_COTIA=
VITE_ALICE_AES_KEY_FOR_COTI=
VITE_BOB_PK_FOR_COTI=
VITE_BOB_AES_KEY_FOR_COTI=
VITE_CONTRACT_ADDRESS_COTI_TESTNET=
COTI_TESTNET_RPC_URL=https://testnet.coti.io/rpc

# --- Sepolia + PoD page (`/sepolia`) — useMillionaireContractPod ---
VITE_ALICE_PK=
VITE_ALICE_AES_KEY=
VITE_BOB_PK=
VITE_BOB_AES_KEY=
VITE_CONTRACT_ADDRESS_SEPOLIA=
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Optional: gas for COTI compareWealth (default 3_000_000 in code)
# VITE_COMPARE_GAS_LIMIT=5000000

# PoD encryption (see milionaire-pod README)
# VITE_POD_ENCRYPTION_NETWORK=testnet
# VITE_POD_ENCRYPTION_URL=

# Standalone-style fallbacks (optional): if the keys above are empty, hooks still accept
# VITE_CONTRACT_ADDRESS and VITE_APP_NODE_HTTPS_ADDRESS for ../milionaire and ../milionaire-pod alone.

# --- Hardhat (deploy COTI contract from this repo) ---
DEPLOYER_PRIVATE_KEY=
SEPOLIA_PRIVATE_KEY=
ETHERSCAN_API_KEY=
